{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["firefox-webext-browser", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
